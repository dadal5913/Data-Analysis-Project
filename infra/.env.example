# --- Neon (managed Postgres) ---
# Create a project at https://console.neon.tech, grab the pooled connection
# string from the dashboard, and paste it below. It looks like:
#   postgresql://<user>:<password>@<hostname>.neon.tech/<database>?sslmode=require
#
# The SQLAlchemy URL needs the `postgresql+psycopg2://` scheme.
# `sslmode=require` is MANDATORY for Neon. `channel_binding=require` is optional
# but recommended. No local postgres container runs with this stack — the API
# talks directly to Neon over the public internet.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# --- Redis (local container) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Service ports exposed on the host ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Auth / API ---
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- App paths / streaming ---
UPLOAD_DIR=/app/uploads
WS_PRICE_SYMBOLS=AAPL,MSFT,SPY,BTCUSD

# --- Frontend (consumed by Next.js at build/runtime) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/prices
